# Файл конфигурации для RAG системы
# Скопируйте этот файл в .env и заполните своими значениями

API_KEY=

# Путь к модели (можно переопределить через переменную окружения MODEL_PATH)
MODEL_PATH=.../T-lite-it-2.1

# Название модели эмбеддингов
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Директории для хранения векторных БД
PERSIST_DIRECTORY_TECHNIC=chroma_db_technic
PERSIST_DIRECTORY_WORK_PLAN=chroma_db_work_plan
PERSIST_DIRECTORY_ALL_DOCS=chroma_db_all_docs
PERSIST_DIRECTORY_EMPLOYEES=chroma_db_employees
PERSIST_DIRECTORY_SUBDIVISIONS=chroma_db_subdivisions
PERSIST_DIRECTORY_EMPLOYEES_EXAMPLES=chroma_db_employees_examples
PERSIST_DIRECTORY_SUBDIVISIONS_EXAMPLES=chroma_db_subdivisions_examples

# Папки с исходными документами
DOCS_FOLDER_TECHNIC=docs/list_technic
DOCS_FOLDER_WORK_PLAN=docs/work_plan
DOCS_FOLDER_ALL_DOCS=docs/all_docs
DOCS_FOLDER_EMPLOYEES=docs/list_employee
DOCS_FOLDER_SUBDIVISIONS=docs/list_subdivisions

# Пути к справочникам для валидации
EMPLOYEES_REFERENCE_CSV=docs/list_employee/employees_reference.csv
TECHNIC_REFERENCE_CSV=docs/list_technic/technic_reference.csv

# Путь к CSV файлу с примерами аварий
CSV_FILE_PATH=docs/list_subdivisions/test.csv

# Путь к CSV с примерами подразделений
SUBDIVISION_EXAMPLES_CSV=docs/list_subdivisions/subdivisions_examples.csv

# Путь к JSON файлу с ключевыми словами (опционально)
KEYWORDS_JSON_PATH=keywords.json

# Максимальное количество ключевых слов для извлечения
MAX_KEYWORDS_TO_EXTRACT=7

# Настройки пула PostgreSQL
PG_MINCONN=1
PG_MAXCONN=10

# Настройки подключения к PostgreSQL
PG_HOST=
PG_PORT=
PG_DB=
PG_USER=
PG_PASSWORD=
PG_SSLMODE=verify-full
PG_SSLROOTCERT=
