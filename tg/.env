# PostgreSQL
PG_HOSTS=###
PG_PORT=###
PG_DB=###
PG_USER=###
PG_PASSWORD=###
# Путь к SSL сертификату (обычно /home/###/.postgresql/root.crt)
PG_SSL_CA=/home/###/.postgresql/root.crt

# Сессии
SESSION_SECRET=your_strong_secret_key_change_me

# RAG API
RAG_API_BASE=https://###

# Redis (если используется)
REDIS_URL=redis://:your_redis_password_123@localhost:6379