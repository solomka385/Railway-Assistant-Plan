# ============================================
# Конфигурация RAG системы для Docker
# ============================================

# ============================================
# PostgreSQL конфигурация (Yandex Cloud)
# ============================================
PG_HOST=
PG_PORT=
PG_DB=
PG_USER=
PG_PASSWORD=
PG_SSLMODE=require
PG_SSLROOTCERT=
PG_MINCONN=1
PG_MAXCONN=10

# ============================================
# Конфигурация моделей
# ============================================
# Модель монтируется из /home/solomka385/model/vikhr_nemo_12b
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ============================================
# API ключи (опционально)
# ============================================
COHERE_API_KEY=
HUGGINGFACE_API_KEY=

# ============================================
# Настройки обработки
# ============================================
MAX_KEYWORDS_TO_EXTRACT=7

# ============================================
# Логирование
# ============================================
LOG_LEVEL=INFO
