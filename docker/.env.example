# ============================================
# Конфигурация RAG системы для Docker
# ============================================

# ============================================
# PostgreSQL конфигурация
# ============================================
# Хост PostgreSQL (postgres для локального контейнера, или внешний хост)
# Для Yandex Cloud Managed PostgreSQL укажите хосты через запятую
PG_HOST=rc1a-q01m8sd3tphlpsmf.mdb.yandexcloud.net,rc1b-3r2a1i9l5k8pdrb8.mdb.yandexcloud.net,rc1b-7mu3abqjkfnqkjid.mdb.yandexcloud.net

# Порт PostgreSQL
PG_PORT=6432

# Имя базы данных
PG_DB=db1

# Пользователь PostgreSQL
PG_USER=test_cla

# Пароль PostgreSQL
PG_PASSWORD=12345678

# Режим SSL (disable для локального, verify-full для облачных БД)
PG_SSLMODE=verify-full

# Путь к SSL сертификату (для облачных БД)
# Для Yandex Cloud сертификат будет скачан автоматически
PG_SSLROOTCERT=

# Минимальное количество соединений в пуле
PG_MINCONN=1

# Максимальное количество соединений в пуле
PG_MAXCONN=10

# ============================================
# Конфигурация моделей
# ============================================

# Путь к модели LLM на хосте (для монтирования в контейнер)
# Windows: E:/диплом/vikhr_nemo_12b
# Linux/Mac: /path/to/vikhr_nemo_12b
MODEL_HOST_PATH=E:/диплом/vikhr_nemo_12b

# Название модели для эмбеддингов (скачивается из HuggingFace)
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ============================================
# API ключи (опционально)
# ============================================

# API ключ Cohere (если используется)
COHERE_API_KEY=

# API ключ HuggingFace (для приватных моделей)
HUGGINGFACE_API_KEY=

# ============================================
# Настройки обработки
# ============================================

# Максимальное количество ключевых слов для извлечения
MAX_KEYWORDS_TO_EXTRACT=7

# ============================================
# Логирование
# ============================================

# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
